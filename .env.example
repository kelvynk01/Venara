# =============================================================================
# Venara — environment variables
# Copy to `.env` and fill in. NEVER commit `.env`. Every secret lives here,
# never in code (Brief §17). Connected-app login credentials are NOT stored
# here — they go through the secret store as `credentialsRef`.
# =============================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# --- Database (PostgreSQL, Railway managed) --------------------------------
# Used by Prisma in packages/db.
DATABASE_URL=postgresql://user:password@localhost:5432/venara?schema=public

# --- Redis (Railway managed) — backs BullMQ --------------------------------
REDIS_URL=redis://localhost:6379

# --- API server (apps/api) -------------------------------------------------
API_HOST=0.0.0.0
API_PORT=4000
# Comma-separated origins allowed to call the API (the dashboard origin).
API_CORS_ORIGINS=http://localhost:3000

# --- Dashboard (apps/dashboard) --------------------------------------------
# Public base URL of the Fastify API, used by the Next.js frontend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# --- Landing site (apps/landing) -------------------------------------------
# Where the marketing site links users for login/signup — the product dashboard.
# In prod the dashboard lives at https://app.venara.ai; locally it's :3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Clerk (auth) ----------------------------------------------------------
# JWT verified on every API request; frontend uses publishable key.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Issuer / JWKS used by the API to verify Clerk JWTs.
CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# Comma-separated authorized parties (azp) the API will accept — the dashboard origin(s).
# Recommended in production so a token minted for another app/key is rejected.
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
# Webhook signing secret (Clerk → /v1/webhooks/clerk).
CLERK_WEBHOOK_SECRET=whsec_xxx

# --- Connected-app credential encryption (Brief §17) -----------------------
# base64-encoded 32-byte key. Generate: `openssl rand -base64 32`
# Used to AES-256-GCM encrypt connected-app login credentials at rest.
CREDENTIALS_ENCRYPTION_KEY=

# --- Bull Board (admin-only queue monitoring) ------------------------------
# Basic-auth gate for the /admin/queues dashboard.
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=change-me

# --- Stripe (billing) ------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Anthropic (agent / planning / vision LLM) -----------------------------
ANTHROPIC_API_KEY=sk-ant-xxx

# --- ElevenLabs (voiceover, TtsProvider) -----------------------------------
ELEVENLABS_API_KEY=xxx

# --- Avatar provider (presenter avatar, Pro tier) --------------------------
AVATAR_PROVIDER_API_KEY=xxx

# --- Browserbase (browser automation / capture) ---------------------------
BROWSERBASE_API_KEY=xxx
BROWSERBASE_PROJECT_ID=xxx

# --- Cloudflare R2 (object storage) ----------------------------------------
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET=venara-media
# S3-compatible endpoint for R2.
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# --- Resend (transactional + staleness email) ------------------------------
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Venara <hello@venara.ai>

# --- PostHog (product analytics) -------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Sentry (error monitoring: api, worker, frontend) ----------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
